INSERT INTO `tours` (`id`, `tour_code`, `name`, `category`, `price`, `duration`, `location`, `status`, `image_url`, `description`, `highlights`, `itinerary`, `policy`, `created_at`) VALUES
(1, 'CJ-VN-001', 'Khám Phá Vịnh Hạ Long - Du Thuyền 5 Sao', 'Nghỉ dưỡng', 2500000.00, '2 Ngày 1 Đêm', 'Hạ Long, Việt Nam', 'active', 'uploads/Ha Long Bay Vietnam.jfif', 'Trải nghiệm một đêm trên du thuyền sang trọng tại Vịnh Hạ Long, di sản thiên nhiên thế giới. Thưởng thức hải sản tươi ngon, chèo kayak và khám phá hang Sửng Sốt.', 'Ngủ đêm trên du thuyền 5 sao\r\nTham quan hang Sửng Sốt\r\nChèo thuyền kayak tại khu vực Hang Luồn\r\nLớp học nấu ăn và tiệc Sunset Party', 'Ngày 1: Hà Nội - Hạ Long, nhận phòng du thuyền, ăn trưa, chèo kayak.\r\nNgày 2: Thăm hang Sửng Sốt, ăn sáng, trả phòng, về Hà Nội.', 'Hủy trước 7 ngày hoàn 100%. Hủy trong vòng 7 ngày không hoàn tiền.', '2026-04-15 14:50:53'),
(2, 'CJ-VN-002', 'Chinh Phục Fansipan - Sapa Mùa Mây', 'Khám phá', 3200000.00, '3 Ngày 2 Đêm', 'Sapa, Việt Nam', 'active', 'uploads/sapa.jpg', 'Hành trình chinh phục nóc nhà Đông Dương và khám phá vẻ đẹp hùng vĩ của Sapa. Tham quan bản Cát Cát, thưởng thức đặc sản núi rừng và săn mây.', 'Chinh phục đỉnh Fansipan bằng cáp treo\nTham quan bản Cát Cát của người H\'Mông\nCheck-in tại Cổng Trời Ô Quy Hồ\nThưởng thức lẩu cá tầm', 'Ngày 1: Hà Nội - Sapa, check-in khách sạn.\nNgày 2: Chinh phục Fansipan, thăm nhà thờ Đá.\nNgày 3: Tham quan bản Cát Cát, mua sắm, về Hà Nội.', 'Hủy trước 10 ngày hoàn 100%. Hủy trong vòng 10 ngày phạt 50%.', '2026-04-15 14:50:53'),
(3, 'CJ-VN-003', 'Đà Nẵng - Hội An - Bà Nà Hills', 'Giải trí', 4500000.00, '4 Ngày 3 Đêm', 'Đà Nẵng, Việt Nam', 'active', 'uploads/danang.jpg', 'Khám phá thành phố đáng sống nhất Việt Nam với bãi biển Mỹ Khê, Cầu Vàng, và phố cổ Hội An lung linh về đêm.', 'Vui chơi tại Bà Nà Hills và Cầu Vàng\nĐi dạo phố cổ Hội An\nTắm biển Mỹ Khê\nThưởng thức ẩm thực Đà Nẵng', 'Ngày 1: Đến Đà Nẵng, tắm biển.\nNgày 2: Khám phá Bà Nà Hills.\nNgày 3: Ngũ Hành Sơn, Phố cổ Hội An.\nNgày 4: Mua sắm, ra sân bay.', 'Chính sách hủy linh hoạt, vui lòng liên hệ để biết chi tiết.', '2026-04-15 14:50:53'),
(4, 'CJ-VN-004', 'Đà Lạt - Thành Phố Ngàn Hoa', 'Nghỉ dưỡng', 2800000.00, '3 Ngày 2 Đêm', 'Đà Lạt, Việt Nam', 'active', 'uploads/dalat.jpg', 'Tận hưởng không khí se lạnh và vẻ đẹp lãng mạn của Đà Lạt. Tham quan các vườn hoa, thác nước và thưởng thức cà phê phố núi.', 'Săn mây tại Đồi chè Cầu Đất\nTham quan vườn hoa thành phố\nCheck-in tại quảng trường Lâm Viên\nThưởng thức ẩm thực chợ đêm Đà Lạt', 'Ngày 1: Đến Đà Lạt, nhận phòng, tự do khám phá.\nNgày 2: Tham quan các điểm nổi tiếng: Thác Datanla, Vườn hoa, Dinh Bảo Đại.\nNgày 3: Mua sắm đặc sản, ra sân bay.', 'Hủy trước 5 ngày hoàn 100%.', '2026-04-15 14:50:53'),
(5, 'CJ-VN-005', 'Phú Quốc - Thiên Đường Biển Đảo', 'Nghỉ dưỡng', 5500000.00, '4 Ngày 3 Đêm', 'Phú Quốc, Việt Nam', 'active', 'uploads/Phu Quoc.jfif', 'Thư giãn trên những bãi biển cát trắng mịn, lặn ngắm san hô và khám phá các hòn đảo hoang sơ tại Phú Quốc.', 'Lặn ngắm san hô tại Hòn Thơm\r\nTham quan nhà tù Phú Quốc\r\nThư giãn tại Bãi Sao\r\nVui chơi tại VinWonders', 'Ngày 1: Đến Phú Quốc, nhận phòng.\r\nNgày 2: Tour 4 đảo, lặn ngắm san hô.\r\nNgày 3: Khám phá Bắc đảo: VinWonders, Safari.\r\nNgày 4: Tự do, ra sân bay.', 'Hủy trước 15 ngày hoàn 100%. Hủy trong vòng 15 ngày phạt 30%.', '2026-04-15 14:50:53'),
(6, 'CJ-QT-001', 'Hàn Quốc Mùa Thu: Seoul - Nami - Everland', 'Văn hóa', 15990000.00, '5 Ngày 4 Đêm', 'Hàn Quốc', 'active', 'uploads/download (1).jfif', 'Đắm chìm trong sắc lá đỏ lãng mạn của mùa thu Hàn Quốc. Khám phá cung điện Gyeongbok, đảo Nami và công viên giải trí Everland.', 'Mặc Hanbok chụp ảnh tại cung điện Gyeongbok\r\nĐi dạo trên đảo Nami lãng mạn\r\nThỏa sức vui chơi tại Everland\r\nShopping tại Myeongdong', 'Ngày 1: Bay đến Seoul.\r\nNgày 2: Tham quan cung điện, làng cổ Bukchon.\r\nNgày 3: Khám phá đảo Nami.\r\nNgày 4: Vui chơi tại Everland, mua sắm.\r\nNgày 5: Ra sân bay về Việt Nam.', 'Yêu cầu có visa Hàn Quốc. Không hoàn hủy sau khi đã đặt.', '2026-04-15 14:50:53'),
(7, 'CJ-QT-002', 'Nhật Bản Mùa Hoa Anh Đào: Tokyo - Kyoto - Osaka', 'Văn hóa', 35500000.00, '7 Ngày 6 Đêm', 'Nhật Bản', 'active', 'uploads/download.jfif', 'Hành trình ngắm hoa anh đào nở rộ trên khắp các thành phố nổi tiếng của Nhật Bản. Trải nghiệm văn hóa độc đáo và ẩm thực tinh tế.', 'Ngắm hoa anh đào tại công viên Ueno\r\nTham quan chùa Vàng Kinkaku-ji ở Kyoto\r\nTrải nghiệm tàu Shinkansen\r\nKhám phá khu Dotonbori ở Osaka', 'Ngày 1-2: Tokyo, núi Phú Sĩ.\r\nNgày 3-4: Di chuyển đến Kyoto, tham quan chùa chiền.\r\nNgày 5-6: Khám phá Osaka, Nara.\r\nNgày 7: Bay về Việt Nam.', 'Yêu cầu có visa Nhật Bản. Không hoàn hủy sau khi đã đặt.', '2026-04-15 14:50:53'),
(8, 'CJ-QT-003', 'Thái Lan: Bangkok - Pattaya - Chợ Nổi', 'Giải trí', 6990000.00, '5 Ngày 4 Đêm', 'Thái Lan', 'active', 'uploads/Bangkok Travel Guide 2026_ Explore Thailand’s Capital City.jfif', 'Khám phá sự sôi động của Bangkok và vẻ đẹp của thành phố biển Pattaya. Thưởng thức show diễn, mua sắm và các món ăn đường phố.', 'Tham quan Cung điện Hoàng Gia Thái Lan\r\nĐi thuyền trên sông Chao Phraya\r\nXem Alcazar Show tại Pattaya\r\nKhám phá chợ nổi Damnoen Saduak', 'Ngày 1: Đến Bangkok, di chuyển đến Pattaya.\r\nNgày 2: Đảo san hô Coral, xem show.\r\nNgày 3: Về Bangkok, tham quan chùa.\r\nNgày 4: Chợ nổi, tự do mua sắm.\r\nNgày 5: Ra sân bay về Việt Nam.', 'Giá tour không bao gồm chi phí cá nhân. Hủy trước 10 ngày hoàn 70%.', '2026-04-15 14:50:53'),
(9, 'CJ-VN-006', 'Hà Giang - Cung Đường Hạnh Phúc', 'Khám phá', 3800000.00, '4 Ngày 3 Đêm', 'Hà Giang, Việt Nam', 'active', 'uploads/Dốc 9 khoanh Hà Giang.jfif', 'Chinh phục những cung đường đèo hiểm trở và hùng vĩ nhất Việt Nam. Ngắm nhìn sông Nho Quế và cột cờ Lũng Cú.', 'Chinh phục đèo Mã Pí Lèng\r\nĐi thuyền trên sông Nho Quế\r\nCheck-in Cột cờ Lũng Cú\r\nTham quan Dinh thự họ Vương', 'Ngày 1: Hà Nội - Hà Giang.\r\nNgày 2: Quản Bạ - Yên Minh - Đồng Văn.\r\nNgày 3: Lũng Cú - Mã Pí Lèng - Mèo Vạc.\r\nNgày 4: Mèo Vạc - Hà Nội.', 'Tour mạo hiểm, yêu cầu sức khỏe tốt.', '2026-04-15 14:50:53'),
(10, 'CJ-VN-007', 'Miền Tây Sông Nước: Cần Thơ - Châu Đốc', 'Văn hóa', 2200000.00, '2 Ngày 1 Đêm', 'Miền Tây, Việt Nam', 'active', 'uploads/poster Cần Thơ.jfif', 'Trải nghiệm cuộc sống sông nước đặc trưng của miền Tây. Đi chợ nổi, nghe đờn ca tài tử và thưởng thức trái cây tại vườn.', 'Đi chợ nổi Cái Răng\r\nTham quan miếu Bà Chúa Xứ\r\nThưởng thức trái cây tại vườn\r\nNghe đờn ca tài tử trên sông', 'Ngày 1: Sài Gòn - Cần Thơ, tham quan nhà cổ, bến Ninh Kiều.\r\nNgày 2: Đi chợ nổi Cái Răng, đến Châu Đốc, về lại Sài Gòn.', 'Tour khởi hành cuối tuần.', '2026-04-15 14:50:53');

